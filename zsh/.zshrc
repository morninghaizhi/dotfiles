# ~/.zshrc
# 対話的シェル起動時にのみ読まれる
# alias, プロンプト, 補完, キーバインドなど「人間が対話的に使う機能」を記述する

# ------------------------------------------------------------
# alias
# ------------------------------------------------------------
alias python='python3'
alias pip='pip3'

# ------------------------------------------------------------
# プロンプト (Starship)
# ------------------------------------------------------------
eval "$(starship init zsh)"
